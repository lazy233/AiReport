# 本地直连 PostgreSQL（本机未用 Docker 跑库时使用）
DATABASE_URL=postgresql+psycopg2://postgres:123456@127.0.0.1:5432/ppt_report_platform

# Docker Compose：与 docker-compose.yml 中 db 服务一致（部署前请改密码）
POSTGRES_USER=pptreport
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ppt_report_platform

# 宿主机映射端口（docker compose 使用）
HOST_PORT=5000

# 阿里百炼（必填才能生成）
DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen3-max
